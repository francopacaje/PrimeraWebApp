@model List<PrimeraWebApp.Models.Usuario>

<div class="container mt-4">
    <h2>Gestión de Usuarios</h2>
    <hr />

    <!-- Formulario ARRIBA -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Registrar Nuevo Usuario</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Nombre Completo</label>
                        <input type="text" name="Nombre" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input type="email" name="Correo" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" name="Contrasena" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Rol del Sistema</label>
                        <select name="Rol" class="form-select" required>
                            <option value="Administrador">Administrador</option>
                            <option value="Vendedor">Vendedor</option>
                        </select>
                    </div>
                </div>
                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-success px-4">Guardar Usuario</button>
                </div>
            </form>
        </div>
    </div>

    <!-- TABLA ABAJO -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white"><h5 class="mb-0">Usuarios en el Sistema</h5></div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.IdUsuario</td>
                                <td>@u.Nombre</td>
                                <td>@u.Correo</td>
                                <td><span class="badge bg-info text-dark">@u.Rol</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
