@model List<PrimeraWebApp.Models.Producto>

<div class="container mt-4">
    <h2>Gestión de Inventario de Productos</h2>
    <hr />

    <!-- Alertas de Error por si ingresan stock negativo -->
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>¡Atención!</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Formulario de ingreso de producto -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Nuevo Producto (Acceso Seguro ADO.NET)</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Nombre del Producto</label>
                        <input type="text" name="Nombre" class="form-control" placeholder="Ej: Arroz 1kg" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Precio ($)</label>
                        <input type="number" name="Precio" class="form-control" placeholder="0" min="0" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Stock Inicial</label>
                        <input type="number" name="Stock" class="form-control" placeholder="0" required />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Categoría</label>
                        <select name="IdCategoria" class="form-select" required>
                            <option value="">-- Seleccione --</option>
                            <option value="1">Abarrotes</option>
                            <option value="2">Bebidas / Líquidos</option>
                            <option value="3">Limpieza</option>
                        </select>
                        <small class="text-muted">Verifica los IDs en tu base de datos</small>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-plus-circle"></i> Guardar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- LISTADO DE PRODUCTOS -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Productos Registrados</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Nombre del Producto</th>
                        <th>Precio</th>
                        <th>Stock Actual</th>
                        <th>Categoría</th>
                        <th style="width: 160px;" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var prod in Model)
                        {
                            <tr>
                                <td>@prod.Id</td>
                                <td>@prod.Nombre</td>
                                <td>$@prod.Precio.ToString("N0")</td>
                                <td>
                                    <span class="badge @(prod.Stock <= 5 ? "bg-danger" : "bg-success")">
                                        @prod.Stock unidades
                                    </span>
                                </td>
                                <td>@prod.NombreCategoria</td>
                                <td class="text-center">
                                    <a asp-action="Editar" asp-route-id="@prod.Id" class="btn btn-warning btn-sm">Editar</a>
                                    <a asp-action="Eliminar" asp-route-id="@prod.Id" class="btn btn-danger btn-sm" onclick="return confirm('¿Seguro de eliminar este producto?');">Eliminar</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No hay productos registrados en el sistema.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>