@model List<PrimeraWebApp.Models.Historial>

@{
    ViewData["Title"] = "Auditoría de Movimientos";
}

<div class="container mt-4">
    <h2>Auditoría de Movimientos</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm mt-3">
        <div class="card-body p-0">
            <table class="table table-striped table-hover m-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Tipo de Movimiento</th>
                        <th>Fecha y Hora</th>
                        <th>Usuario Responsable</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.IdHistorial</td>
                            <td class="fw-bold">@item.NombreProducto</td>
                            <td>@item.CantidadMovimiento unidades</td>
                            <td>
                                <span class="badge bg-success">
                                    @item.TipoMovimiento
                                </span>
                            </td>
                            <td>@item.FechaHora.ToString("dd-MM-yyyy HH:mm:ss")</td>
                            <td>
                                <span class="badge bg-primary">
                                    @item.NombreUsuario
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>