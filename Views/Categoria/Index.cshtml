@model List<PrimeraWebApp.Models.Categoria>

<div class="container mt-4">
    <h2>Gestión de Categorías</h2>
    <hr />

    <!-- Mensajes de Error si ocurren -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>¡Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Formulario de ingreso ARRIBA de la tabla (Criterio de Éxito) -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Nueva Categoría</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row g-3 align-items-end">
                    <!-- input con name idéntico a la propiedad del Modelo -->
                    <div class="col-md-9">
                        <label class="form-label">Nombre de la Categoría</label>
                        <input type="text" name="Nombre" class="form-control" placeholder="Ej: Lacteos, Congelados..." required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            Guardar Categoría
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- TABLA DE LISTADO -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Categorías Disponibles</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 150px;">ID Categoría</th>
                        <th>Nombre de la Categoría</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td>@cat.IdCategoria</td>
                                <td>@cat.Nombre</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted py-4">
                                No hay categorías registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>